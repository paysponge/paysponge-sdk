{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "paths": {
      "@paysponge/sdk": ["./src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "examples/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/api/generated/heyapi/**/*",
    "src/api/generated/heyapi-adapter.ts"
  ]
}
